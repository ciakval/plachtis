# Copy this file to .env in your deploy directory and adjust values.

# Required secret
DJANGO_SECRET_KEY=replace-with-strong-random-secret

# Image selection (overwritten by CI deploy)
GITHUB_REPOSITORY=owner/repo
IMAGE_TAG=latest

# Runtime settings
CONTAINER_NAME=plachtis-web
DJANGO_ALLOWED_HOSTS=plachtis.remesh.cz,plachtis.skare.cz
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# Test environment example values:
# CONTAINER_NAME=plachtis-test-web
# DJANGO_ALLOWED_HOSTS=plachtis-test.remesh.cz
# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-strong-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=plachtis.remesh.cz

# Database (for future use if switching from SQLite)
# DATABASE_URL=sqlite:///db.sqlite3

# RFID reader API authentication
RFID_API_KEY=replace-with-strong-random-secret
